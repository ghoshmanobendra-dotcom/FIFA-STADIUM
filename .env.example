# ---------------------------------------------------------------------------
# StadiumIQ 2026 — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# HTTP server port
PORT=3000

# Runtime environment: development | production | test
NODE_ENV=development

# --- Generative AI provider (Anthropic Claude) -----------------------------
# If no key is provided the app automatically falls back to a fully
# deterministic, offline knowledge-base engine so the platform still runs.
ANTHROPIC_API_KEY=
# Latest Claude models: claude-opus-4-8, claude-sonnet-5, claude-haiku-4-5-20251001
AI_MODEL=claude-sonnet-5
AI_MAX_TOKENS=1024

# Comma-separated list of allowed CORS origins (use * only for local dev)
CORS_ORIGINS=*

# Rate limiting (requests per window per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
